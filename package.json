{
  "name": "clawctl",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/web && npm run build -w packages/server",
    "start": "tsx packages/cli/src/index.ts",
    "test": "vitest run packages/server",
    "test:unit": "vitest run packages/server",
    "test:components": "vitest run --config packages/web/vitest.config.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:live": "vitest run packages/server/src/__tests__/live.test.ts",
    "test:all": "vitest run packages/server && vitest run --config packages/web/vitest.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^16.5.6"
  }
}
